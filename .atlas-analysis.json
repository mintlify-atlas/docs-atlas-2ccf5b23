  "keyFeatures": [
    "Natural language coding via terminal REPL",
    "Agentic tool execution (file read/write/edit, bash, grep, glob)",
    "Git workflow automation (commit, review, PR comments, diff)",
    "MCP (Model Context Protocol) server integration",
    "Multi-agent orchestration and agent swarms",
    "Skill system for reusable workflows",
